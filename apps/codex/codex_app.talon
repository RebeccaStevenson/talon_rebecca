os: mac
app.bundle: com.openai.codex
-
command menu open: key(cmd-shift-p)

command menu open quick: key(cmd-k)

settings open: key(cmd-,)

folder open: key(cmd-o)

navigate back: key(cmd-[)

navigate forward: key(cmd-])

font size increase: key(cmd-=)

font size decrease: key(cmd--)

sidebar toggle: key(cmd-b)

diff panel toggle: key(cmd-alt-b)

terminal toggle: key(cmd-j)

terminal clear: key(ctrl-l)

thread new: key(cmd-n)

thread new alternate: key(cmd-shift-o)

thread find: key(cmd-f)

thread previous: key(cmd-shift-[)

thread next: key(cmd-shift-])

dictation toggle: key(ctrl-m)
